## Kairos backend environment (example)
## Copy to `kairos-backend/.env` for local dev, or set these as variables in Railway/Fly/Render/etc.
## Never commit real secrets (private keys / API keys).
##
## Railway: add these in the service Variables tab (repo has no production .env). `PORT` is set by Railway.
## For a green deploy, set at least GROQ_API_KEY plus X Layer (or HashKey legacy) RPC + treasury key.

# Payments / chain targeting
KAIROS_CHAIN_TARGET=xlayer
KAIROS_PAYMENTS=hashkey

# X Layer (OKX) — hackathon target
XLAYER_RPC_URL=https://xlayertestrpc.okx.com/terigon
XLAYER_CHAIN_ID=1952
XLAYER_EXPLORER_BASE=https://www.okx.com/web3/explorer/xlayer-test
XLAYER_NATIVE_SYMBOL=OKB
XLAYER_NETWORK_LABEL="X Layer Testnet"

# Treasury (agentic wallet identity) — REQUIRED for on-chain settlement
KAIROS_TREASURY_PRIVATE_KEY=0xYOUR_TREASURY_PRIVATE_KEY

# Deployed contracts (X Layer testnet)
KAIROS_AGENT_REGISTRY_EVM_ADDRESS=0xYOUR_AGENT_REGISTRY_ADDRESS
KAIROS_SPENDING_POLICY_EVM_ADDRESS=0xYOUR_SPENDING_POLICY_ADDRESS

# Optional: make demos resilient on low balances
# KAIROS_DEFAULT_AGENT_PRICE_NATIVE=0.00001
# KAIROS_TREASURY_TX_WAIT_CONFIRMS=0

# AI provider
GROQ_API_KEY=YOUR_GROQ_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: web search grounding
# KAIROS_WEB_SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=YOUR_BRAVE_KEY

# Optional: market data
# COINGECKO_API_KEY=YOUR_COINGECKO_KEY

# Persistence (recommended for production): ratings, chat, query_logs — see SUPABASE_SETUP.md
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...   # anon public key (Project Settings → API)

# Agent wallets (EOA addresses + private keys) — required only for demo loop / A2A
# ORACLE_EVM_PRIVATE_KEY=0x...
# ORACLE_EVM_ADDRESS=0x...
# NEWS_EVM_PRIVATE_KEY=0x...
# NEWS_EVM_ADDRESS=0x...
# YIELD_EVM_PRIVATE_KEY=0x...
# YIELD_EVM_ADDRESS=0x...
# TOKENOMICS_EVM_PRIVATE_KEY=0x...
# TOKENOMICS_EVM_ADDRESS=0x...
# PERP_EVM_PRIVATE_KEY=0x...
# PERP_EVM_ADDRESS=0x...
# CHAIN_SCOUT_EVM_PRIVATE_KEY=0x...
# CHAIN_SCOUT_EVM_ADDRESS=0x...
# PROTOCOL_EVM_PRIVATE_KEY=0x...
# PROTOCOL_EVM_ADDRESS=0x...
# BRIDGES_EVM_PRIVATE_KEY=0x...
# BRIDGES_EVM_ADDRESS=0x...
# DEX_VOLUMES_EVM_PRIVATE_KEY=0x...
# DEX_VOLUMES_EVM_ADDRESS=0x...
